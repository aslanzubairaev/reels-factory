# =============================================================
# Reels Factory — environment variables
# Скопируй этот файл в .env и заполни ключи.
# .env попадает под .gitignore и хуки защиты — не будет закоммичен.
# =============================================================

# --- Google Gemini (фоны, обложки) ---
# Нужен для AI-фонов и AI-обложек.
# Получить: https://aistudio.google.com → Get API Key
# ВАЖНО: включи billing в Google Cloud Console — free tier не поддерживает
# генерацию изображений (model gemini-3-pro-image-preview).
GEMINI_API_KEY=AIzaSy...your_key_here

# --- Anthropic Claude (опционально) ---
# Используется только:
#   - /api/generate для перевода промптов на английский
#   - /api/ai-slide-data для генерации данных HTML-слайдов
# Если не юзаешь AI-перевод и AI-слайды — можно оставить пустым.
# Получить: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_key_here

# --- PiAPI / Seedance (опционально) ---
# Альтернатива Veo 3 для AI-видео. Обычно не нужен, если только не делаешь
# видео-фоны через Seedance.
# Получить: https://piapi.ai → Workspace → API Key
PIAPI_KEY=your_key_here

# --- OpenAI (опционально) ---
# Fallback для generate-photo если Gemini недоступен (DALL-E 3).
# Whisper работает локально — OpenAI API ключ для транскрипции НЕ нужен.
# Получить: https://platform.openai.com → API keys
OPENAI_API_KEY=your_key_here

# --- Studio server ---
# Порт локальной студии. Если 3000 занят — поменяй.
PORT=3000

# --- Опционально: переопределить папку проектов ---
# По умолчанию — <repo>/projects/
# REELS_FACTORY_PROJECTS_DIR=/path/to/my/reels
